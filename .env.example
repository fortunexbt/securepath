# Live integrations are optional. The offline replay needs none of these values.
SECUREPATH_PROVIDER=perplexity
PERPLEXITY_API_KEY=
OPENAI_API_KEY=
DISCORD_TOKEN=

# Optional provider/runtime overrides.
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_API_URL=https://api.perplexity.ai/chat/completions
OPENAI_MODEL=gpt-5
SECUREPATH_TIMEOUT_SECONDS=45
SECUREPATH_COMMAND_PREFIX=!
SECUREPATH_RATE_LIMIT_COUNT=5
SECUREPATH_RATE_LIMIT_SECONDS=60

